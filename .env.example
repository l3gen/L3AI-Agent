# ─────────────────────────────────────────
# Levatas Demo — Environment Configuration
# Copy to .env and fill in real values
# Never commit .env to version control
# ─────────────────────────────────────────

# Service ports (host-side mappings)
INGESTION_PORT=5010
AI_PORT=5011
REVIEW_PORT=5012
DASHBOARD_PORT=3009

# AI Service
CONFIDENCE_THRESHOLD=0.70   # Below this → routed to human review queue

# GPU Runtime (for production AI workloads)
# Set to "nvidia" to enable GPU acceleration for the AI service
# Requires: nvidia-container-toolkit installed on the host
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
# Runtime must be set in docker-compose:
#   runtime: nvidia

# Dashboard URLs (baked into Vite build — must match INGESTION_PORT/REVIEW_PORT)
VITE_INGESTION_URL=http://localhost:5010
VITE_REVIEW_URL=http://localhost:5012

# Registry (for pushing images in CI)
REGISTRY=ghcr.io
IMAGE_OWNER=your-github-username
